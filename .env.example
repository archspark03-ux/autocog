# ===== BİRİNCİ DƏRƏCƏLİ: PULSUZ LİMİTSİZ LOKAL/CLOUD BEYİN =====
# Z.ai GLM-4.5-Flash - TAM PULSUZ, LİMİTSİZ, 128K ctx
# Key: https://bigmodel.cn/  (qeydiyyat, kart istəmir)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.5-flash
GLM_THINKING_MODEL=glm-z1-air

# ===== İKİNCİ DƏRƏCƏLİ: DƏRİN ARAŞDIRMA (göz + əl) =====
# Tavily - 1000 pulsuz credit/ay
# Key: https://app.tavily.com/
TAVILY_API_KEY=

# Firecrawl - 500 pulsuz credit (səndə Trae MCP var, lakin burada da qoşa bilərik)
# Key: https://firecrawl.dev/
FIRECRAWL_API_KEY=

# ===== ÜÇÜNCÜ DƏRƏCƏLİ: BACKUP-LAR =====
# OpenRouter - 35+ pulsuz model (DeepSeek R2, Qwen3-235B, GLM-4.7 və s.)
# Key: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq - ultra-sürətli pulsuz inference (Llama 3.3 70B, Qwen3 32B)
# Key: https://console.groq.com/
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Cerebras - Qwen3 235B pulsuz 1M token/gün
# Key: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Pollinations - daxili (key tələb etmir, lakin "sk_..." ilə daha yüksək limit)
POLLINATIONS_API_KEY=

# ===== RENDER DEPLOYMENT (avtomatik) =====
# Render API key (Dashboard → Account Settings → API Keys)
RENDER_API_KEY=

# Neon PostgreSQL (7/24 persistent storage)
# https://console.neon.tech/ - pulsuz tier
DATABASE_URL=

# Dashboard token (avtomatik yaradılır)
DASHBOARD_TOKEN=

# DeepSeek - 5M pulsuz token + sonra 20-100x ucuz
# Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama - LOKAL TAM LİMİTSİZ (kompüterin gücündən asılı)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
OLLAMA_THINKING_MODEL=qwen3:14b

# ===== DÖVLƏT VƏ DAVRANIS =====
# Əsas beyin: glm | openrouter | groq | cerebras | ollama | deepseek
PRIMARY_BRAIN=glm
FALLBACK_BRAIN=ollama

# Araşdırma hər loop-da edilsin?
DEEP_RESEARCH_EVERY_LOOP=false

# Loop intervalı (saniyə) - əsas beyin nə qədər tez-tez "düşünsün"
LOOP_INTERVAL_SECONDS=300

# Plan: n8n, Avtonom Agent, EDR, Təhlükəsizlik, Etdim...
USER_GOAL=Davamlı şəkildə düşün, araşdır, öyrən və qeydlər yaz. Mən olmayanda da inkişaf et.
